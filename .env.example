# --- Google Reviews (optional) ---
# The reviews section works out of the box with curated fallback reviews + an
# embedded Google Map. To show LIVE Google reviews, point this at a small proxy
# that calls the Google Places "Place Details" endpoint server-side and returns
# { reviews: [...], rating: number }. See README → "Google Reviews".
VITE_REVIEWS_ENDPOINT=

# If your proxy reads the key from the frontend build (not recommended), you can
# stash it here. Prefer keeping the key on the server.
VITE_GOOGLE_PLACES_API_KEY=
